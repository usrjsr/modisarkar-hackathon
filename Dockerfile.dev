FROM node:20-alpine

WORKDIR /app

# Install dependencies first (caching layer)
COPY package.json package-lock.json* ./
RUN npm install && npm cache clean --force

# Copying all files isn't strictly necessary since we use volumes in dev,
# but it's good practice for cases where the volume mount fails.
COPY . .

# Expose port 3000
EXPOSE 3000

# Start development server
CMD ["npm", "run", "dev"]
